# Midtrans Sandbox Keys (isi dari dashboard sandbox Midtrans)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=

# Database (default Laragon, biasanya gak perlu diubah)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=glambot_db

# Google Drive (upload hasil sesi) — lihat cmd/gdrive-token buat generate token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# Folder tempat digiCamControl nyimpen file jepretan full-res ke PC
# (Settings → Transfer → Save to PC). Kosong = fallback HTTP /lastcaptured.
DIGICAM_CAPTURE_DIR=